<Window x:Class="VaultWinnow.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About VaultWinnow"
        Height="Auto"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,8">
    <Run Text="VaultWinnow" />
    <Run Text=" " />
    <Run Text="{Binding VersionText, Mode=OneWay}" />
        </TextBlock>



        <StackPanel Grid.Row="1">
            <TextBlock Text="A small WPF tool for filtering and exporting Bitwarden/Vaultwarden JSON vaults."
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <TextBlock Text="• Load an unencrypted JSON export"
                       Margin="0,0,0,2" />
            <TextBlock Text="• Select items to keep"
                       Margin="0,0,0,2" />
            <TextBlock Text="• Export, copy, or append filtered JSON"
                       Margin="0,0,0,2" />

            <TextBlock Margin="0,10,0,0">
        <Run Text="Source: " />
        <Hyperlink NavigateUri="https://github.com/cliftonfoster/vault-winnow"
                   RequestNavigate="Hyperlink_RequestNavigate">
            <Run Text="github.com/cliftonfoster/vault-winnow" />
        </Hyperlink>
            </TextBlock>

            <TextBlock Margin="0,6,0,0">
        <Run Text="Support development on Ko-fi: " />
        <Hyperlink NavigateUri="https://ko-fi.com/cliftonfoster"
                   RequestNavigate="Hyperlink_RequestNavigate">
            <Run Text="ko-fi.com/cliftonfoster" />
        </Hyperlink>
            </TextBlock>
        </StackPanel>


        <Button Grid.Row="2"
                Content="OK"
                Width="80"
                Height="28"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                IsDefault="True"
                Click="OkButton_Click" />
    </Grid>
</Window>
