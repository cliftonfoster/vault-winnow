<Window x:Class="VaultWinnow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VaultWinnow"
        Height="600" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <!-- Ctrl+O: Open JSON -->
        <KeyBinding Modifiers="Control"
                    Key="O"
                    Command="{Binding OpenCommand}" />

        <!-- Ctrl+W Close file -->
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding CloseCommand}" />

        <!-- Ctrl+E: Export Selected -->
        <KeyBinding Modifiers="Control"
                    Key="E"
                    Command="{Binding ExportCommand}" />

        <!-- Ctrl+C: Copy JSON -->
        <KeyBinding Modifiers="Control"
                    Key="C"
                    Command="{Binding CopyCommand}" />

        <!-- Ctrl+A: Select All (visible) -->
        <KeyBinding Modifiers="Control"
                    Key="A"
                    Command="{Binding SelectAllCommand}" />

        <!-- Ctrl+L: Clear Selection (visible) -->
        <KeyBinding Modifiers="Control"
                    Key="L"
                    Command="{Binding ClearSelectionCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle"
               TargetType="Button">
            <Setter Property="Padding"
                    Value="4,2" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="MinWidth"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

        <!-- Icon + text style that builds on ToolbarButtonStyle -->
        <Style x:Key="ToolbarIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Center">
                            <Image Width="28"
                                   Height="28"
                                   Margin="0,0,0,2"
                                   Source="{Binding RelativeSource={RelativeSource AncestorType=Button},
                                                    Path=Tag}" />       
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="11"
                                       Text="{Binding RelativeSource={RelativeSource AncestorType=Button},
                                                      Path=Content}" />
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
<RowDefinition Height="Auto"/>  <!-- 0 Toolbar -->
<RowDefinition Height="Auto"/>  <!-- 1 Search -->
<RowDefinition Height="Auto" /> <!-- 2 Options (Expander) -->
<RowDefinition Height="*"/>     <!-- 3 DataGrid -->
<RowDefinition Height="Auto"/>  <!-- 4 Footer -->
        </Grid.RowDefinitions>

        <!-- Toolbar Row -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">

            <!-- File actions -->
            <Button Name="BtnOpen"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/open.png"
                    Content="Open"
                    ToolTip="Open JSON File (CTRL+O)"
                    MinWidth="48"
                    Height="52"
                    Click="BtnOpenClick" />

            <Button x:Name="BtnClose"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/close.png"
                    Content="Close"
                    ToolTip="Close current file"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnCloseClick" />

            <Button Name="BtnExport"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-save.png"
                    Content="Export"
                    ToolTip="Export JSON File (CTRL+E)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnExportClick" />

            <Button Name="BtnCopyToClipboard"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-copy.png"
                    Content="Copy"
                    ToolTip="Copy JSON to Clipboard (CTRL+C)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnCopyToClipboardClick" />

            <Button Name="BtnAppendToJson"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-append.png"
                    Content="Append"
                    ToolTip="Append JSON to Existing File"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnAppendToJsonClick" />

            <Separator Margin="8,0,8,0" />

            <!-- Selection actions -->
            <Button Name="BtnSelectAll"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/check-select-all.png"
                    Content="Select"
                    ToolTip="Select All Listed Items (CTRL+A)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnSelectAllClick" />

            <Button Name="BtnClearSelection"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/check-clear.png"
                    Content="Clear"
                    ToolTip="Clear All Listed Items (CTRL+L)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnClearSelectionClick" />

            <Button Name="BtnInvertSelection"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/invert.png"
                    Content="Invert"
                    ToolTip="Invert selection for visible items"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnInvertSelectionClick" />

            <Separator Margin="8,0,8,0" />

            <!-- Duplicate analysis actions -->
            <Button Name="BtnAnalyzeDuplicates"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/analyze.png"
                    Content="Analyze"
                    ToolTip="Analyze logins for duplicates"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnAnalyzeDuplicatesClick" />

            <Button Name="BtnDuplicateHelp"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/message-question.png"
                    Content="Dup Help"
                    ToolTip="Explain Strict / Almost duplicate analysis"
                    MinWidth="48"
                    Height="52"
                    Click="BtnDuplicateHelpClick" />

            <Button Name="BtnSelectStrictDuplicates"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/select-strict.png"
                    Content="Select Strict"
                    ToolTip="Select strict duplicates in the visible items (keep one per group)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnSelectStrictDuplicatesClick" />

            <Separator Margin="8,0,8,0" />

            <!-- App -->
            <Button Name="BtnAbout"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/info.png"
                    Content="About"
                    ToolTip="About VaultWinnow"
                    MinWidth="48"
                    Height="52"
                    Click="BtnAboutClick" />
        </StackPanel>

        <!-- Status Row -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,6">
            <TextBlock Text="Search:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBox Name="TxtSearch"
                     Width="220"
                     TextChanged="TxtSearch_TextChanged" />

            <TextBlock Name="TxtStatus"
                       Text="No file loaded."
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="Gray" />
        </StackPanel>

        <!-- Filters and column options (collapsible) -->
        <Expander Grid.Row="2"
                  Header="Options"
                  IsExpanded="False"
                  Margin="0,0,0,4">
            <StackPanel Orientation="Vertical">

                <!-- Types row -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <TextBlock Text="Types:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />

                    <CheckBox x:Name="ChkLogin"
                              Content="Logins"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="TypeFilterCheckboxChanged"
                              Unchecked="TypeFilterCheckboxChanged" />

                    <CheckBox x:Name="ChkSecureNote"
                              Content="Secure Notes"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="TypeFilterCheckboxChanged"
                              Unchecked="TypeFilterCheckboxChanged" />

                    <CheckBox x:Name="ChkCard"
                              Content="Cards"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="TypeFilterCheckboxChanged"
                              Unchecked="TypeFilterCheckboxChanged" />

                    <CheckBox x:Name="ChkIdentity"
                              Content="Identities"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="TypeFilterCheckboxChanged"
                              Unchecked="TypeFilterCheckboxChanged" />

                    <CheckBox x:Name="ChkShowOnlyDuplicates"
                              Content="Show only duplicates"
                              IsChecked="false"
                              IsEnabled="false"
                              Margin="12,0,0,0"
                              Checked="DuplicatesFilterChanged"
                              Unchecked="DuplicatesFilterChanged" />
                </StackPanel>

                <!-- Columns row -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Columns:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />

                    <CheckBox x:Name="ChkColDup"
                              Content="Dup"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />

                    <CheckBox x:Name="ChkColDupCount"
                              Content="#Dup"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />

                    <CheckBox x:Name="ChkColDupGroup"
                              Content="Grp"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />

                    <CheckBox x:Name="ChkColMfa"
                              Content="MFA"
                              IsChecked="True"
                              Margin="12,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />

                    <CheckBox x:Name="ChkColPasskey"
                              Content="Passkey"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />
                </StackPanel>

            </StackPanel>
        </Expander>
        <!-- DataGrid with watermark -->
        <Grid Grid.Row="3">
            <DataGrid Name="ItemGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      SelectionChanged="ItemGrid_SelectionChanged">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White" />
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="FontWeight" Value="Normal" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="2" />

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInSelectedDuplicateGroup}"
                         Value="True">
                                <Setter Property="Background" Value="#FFD6EBFF" />
                            </DataTrigger>

                            <Trigger Property="IsSelected"
                     Value="True">
                                <Setter Property="Background" Value="#FF7FB8F0" />
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="BorderBrush" Value="#FF2F6FAE" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <!-- Checkbox -->
                    <DataGridTemplateColumn Header="✔"
                                            Width="40"
                                            MinWidth="40"
                                            CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected,
                                              Mode=TwoWay,
                                              UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Main text columns flex -->
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        MinWidth="150"
                                        Width="2*" 
                                        IsReadOnly="True" />

                        <DataGridTextColumn Header="Username"
                                            Binding="{Binding Username}"
                                            MinWidth="120"
                                            Width="*"
                                            IsReadOnly="True" />

                        <DataGridTextColumn Header="Primary URI"
                                            Binding="{Binding PrimaryUri}"
                                            MinWidth="140"
                                            Width="2*"
                                            IsReadOnly="True" />

                        <!-- Small columns, fixed + MinWidth so headers don’t squash -->
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding TypeLabel}"
                                            Width="70"
                                            MinWidth="70"
                                            IsReadOnly="True" />

                    <DataGridTextColumn Header="Dup"
                                        Binding="{Binding DuplicateStatusDisplay}"
                                        Width="80"
                                        IsReadOnly="True">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                        Value="Duplicate status for logins: Strict (safe auto‑select), Almost (needs review), or blank (no duplicates)." />
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="#Dup"
                                        Binding="{Binding DuplicateGroupSize}"
                                        Width="60"
                                        IsReadOnly="True">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                        Value="How many items are in this duplicate group. 1 means no duplicates; 2+ means multiple related logins." />
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Grp"
                                        Binding="{Binding DuplicateGroupId}"
                                        Width="80"
                                        IsReadOnly="True">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                        Value="Stable duplicate group id so related Strict/Almost logins stay together when sorted." />
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Diff"
                    Binding="{Binding DiffDisplay}"
                    Width="90"
                    IsReadOnly="True">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <ToolTip MaxWidth="260">
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="Difference code order:" FontWeight="Bold" />
                                                <LineBreak />
                                                <Run Text="N = Name" />
                                                <LineBreak />
                                                <Run Text="U = Username" />
                                                <LineBreak />
                                                <Run Text="P = Password" />
                                                <LineBreak />
                                                <Run Text="O = Notes" />
                                                <LineBreak />
                                                <Run Text="T = TOTP" />
                                                <LineBreak />
                                                <Run Text="K = Passkey" />
                                                <LineBreak />
                                                <Run Text="Dash (-) means no difference from the selected row." />
                                            </TextBlock>
                                        </ToolTip>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas" />
                                <Setter Property="TextAlignment" Value="Left" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Folder"
                                            Binding="{Binding FolderName}"
                                            Width="80"
                                            MinWidth="50"
                                            IsReadOnly="True" />

                    <DataGridCheckBoxColumn Header="MFA"
                                            Binding="{Binding HasTotp, Mode=OneWay}"
                                            Width="50"
                                            IsReadOnly="True">
                                            <DataGridCheckBoxColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                            Value="Checked if this login has a TOTP MFA code configured." />
                                                </Style>
                                            </DataGridCheckBoxColumn.HeaderStyle>
                    </DataGridCheckBoxColumn>

                    <DataGridCheckBoxColumn Header="Passkey"
                                            Binding="{Binding HasPasskey, Mode=OneWay}"
                                            Width="70"
                                            IsReadOnly="True">
                                            <DataGridCheckBoxColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                            Value="Checked if this login has any passkey (FIDO2) credentials." />
                                                </Style>
                                            </DataGridCheckBoxColumn.HeaderStyle>
                    </DataGridCheckBoxColumn>

                </DataGrid.Columns>
            </DataGrid>

            <!-- Faded logo watermark when there are no items -->
            <Image Source="pack://application:,,,/Assets/VaultWinnowLogo.png"
                   Width="200"
                   Height="200"
                   Opacity="0.33"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Items.Count}"
                             Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="4"
                   Name="TxtCount"
                   Text=""
                   Margin="0,6,0,0"
                   Foreground="DarkSlateBlue"/>
    </Grid>
</Window>
