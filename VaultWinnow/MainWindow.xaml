<Window x:Class="VaultWinnow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VaultWinnow"
        Height="600" Width="950"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <!-- Ctrl+O: Open JSON -->
        <KeyBinding Modifiers="Control"
                    Key="O"
                    Command="{Binding OpenCommand}" />

        <!-- Ctrl+E: Export Selected -->
        <KeyBinding Modifiers="Control"
                    Key="E"
                    Command="{Binding ExportCommand}" />

        <!-- Ctrl+C: Copy JSON -->
        <KeyBinding Modifiers="Control"
                    Key="C"
                    Command="{Binding CopyCommand}" />

        <!-- Ctrl+A: Select All (visible) -->
        <KeyBinding Modifiers="Control"
                    Key="A"
                    Command="{Binding SelectAllCommand}" />

        <!-- Ctrl+L: Clear Selection (visible) -->
        <KeyBinding Modifiers="Control"
                    Key="L"
                    Command="{Binding ClearSelectionCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle"
               TargetType="Button">
            <Setter Property="Padding"
                    Value="4,2" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="MinWidth"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>
        
        <!-- New: icon + text style that builds on ToolbarButtonStyle -->
        <Style x:Key="ToolbarIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Width="24"
                                   Height="24"
                                   Margin="0,0,4,0"
                                   Source="{Binding RelativeSource={RelativeSource AncestorType=Button},
                                            Path=Tag}" />
                            <TextBlock Text="{Binding}" />
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar Row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Name="BtnOpen"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/open.png"
                    Content="Open"
                    ToolTip="Open JSON File (CTRL+O)"
                    Height="32"
                    Click="BtnOpen_Click" />

            <Button Name="BtnExport"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-save.png"
                    Content="Export"
                    ToolTip="Export JSON File (CTRL+E)"
                    Height="32"
                    IsEnabled="False"
                    Click="BtnExport_Click" />
            
            <Button Name="BtnAnalyzeDuplicates"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/duplicates.png"
                    Content="Analyze"
                    ToolTip="Analyze logins for duplicates"
                    Height="32"
                    IsEnabled="False"
                    Click="BtnAnalyzeDuplicatesClick" />
            
            <Button Name="BtnSelectStrictDuplicates"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/select-duplicates.png"
                    Content="Select Strict"
                    ToolTip="Select strict duplicates in the visible items (keep one per group)"
                    Height="32"
                    IsEnabled="False"
                    Click="BtnSelectStrictDuplicatesClick" />

            <Button Name="BtnCopyToClipboard"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-copy.png"
                    Content="Copy"
                    ToolTip="Copy JSON to Clipboard (CTRL+C)"
                    Height="32"
                    IsEnabled="False"
                    Click="BtnCopyToClipboard_Click" />

            <Button Name="BtnAppendToJson"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-append.png"
                    Content="Append"
                    ToolTip="Append JSON to Existing File"
                    Height="32"
                    IsEnabled="False"
                    Click="BtnAppendToJson_Click" />

            <Button Name="BtnSelectAll"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/check-select-all.png"
                    Content="Select"
                    ToolTip="Select All Listed Items (CTRL+A)"
                    Height="32"
                    Click="BtnSelectAll_Click" />

            <Button Name="BtnClearSelection"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/check-clear.png"
                    Content="Clear"
                    ToolTip="Clear All Listed Items (CTRL+L)"
                    Height="32"
                    Click="BtnClearSelection_Click" />

            <Button Name="BtnAbout"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/info.png"
                    Content="About"
                    ToolTip="About VaultWinnow"
                    Height="32"
                    Click="BtnAbout_Click" />
        </StackPanel>

        

        <!-- Status Row -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,6">
            <TextBlock Text="Search:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBox Name="TxtSearch"
                     Width="220"
                     TextChanged="TxtSearch_TextChanged" />
                     
            <TextBlock Name="TxtStatus"
                       Text="No file loaded."
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="Gray" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,4">
            <TextBlock Text="Types:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />

            <CheckBox x:Name="ChkLogin"
                      Content="Logins"
                      IsChecked="True"
                      Margin="0,0,6,0"
                      Checked="TypeFilterCheckboxChanged"
                      Unchecked="TypeFilterCheckboxChanged" />

            <CheckBox x:Name="ChkSecureNote"
                      Content="Secure Notes"
                      IsChecked="True"
                      Margin="0,0,6,0"
                      Checked="TypeFilterCheckboxChanged"
                      Unchecked="TypeFilterCheckboxChanged" />

            <CheckBox x:Name="ChkCard"
                      Content="Cards"
                      IsChecked="True"
                      Margin="0,0,6,0"
                      Checked="TypeFilterCheckboxChanged"
                      Unchecked="TypeFilterCheckboxChanged" />

            <CheckBox x:Name="ChkIdentity"
                      Content="Identities"
                      IsChecked="True"
                      Margin="0,0,6,0"
                      Checked="TypeFilterCheckboxChanged"
                      Unchecked="TypeFilterCheckboxChanged" />
            
            <CheckBox x:Name="ChkShowOnlyDuplicates"
                      Content="Show only duplicates"
                      Margin="12,0,0,0"
                      Checked="DuplicatesFilterChanged"
                      Unchecked="DuplicatesFilterChanged" />

        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3"
                  Name="ItemGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F5F5">

            <DataGrid.Columns>

                <!-- Checkbox column – uses TemplateColumn so one click works -->
                <DataGridTemplateColumn Header="✔" Width="40" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected,
                                        Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    MinWidth="180"
                                    Width="*"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="Username"
                                    Binding="{Binding Username}"
                                    MinWidth="150"
                                    Width="*"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="Primary URI"
                                    Binding="{Binding PrimaryUri}"
                                    MinWidth="220"
                                    Width="2*"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="Type"
                                    Binding="{Binding TypeLabel}"
                                    MinWidth="90"
                                    Width="*"
                                    IsReadOnly="True" />
                <!-- Duplicate status: None / Strict / Almost -->
                <DataGridTextColumn Header="Duplicate"
                                    Binding="{Binding DuplicateStatus}"
                                    Width="80"
                                    IsReadOnly="True" />

                <!-- Group size: how many items share this duplicate group -->
                <DataGridTextColumn Header="#"
                                    Binding="{Binding DuplicateGroupSize}"
                                    Width="40"
                                    IsReadOnly="True" />
                
                <DataGridTextColumn Header="Folder"
                                    Binding="{Binding FolderName}"
                                    MinWidth="90"
                                    Width="*"
                                    IsReadOnly="True" />
                
                <DataGridCheckBoxColumn Header="MFA"
                                        Binding="{Binding HasTotp, Mode=OneWay}"
                                        IsReadOnly="True"
                                        MinWidth="40"
                                        Width="*" />

                <DataGridCheckBoxColumn Header="Passkey"
                                        Binding="{Binding HasPasskey, Mode=OneWay}"
                                        IsReadOnly="True"
                                        MinWidth="40"
                                        Width="*" />

            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <TextBlock Grid.Row="4"
                   Name="TxtCount"
                   Text=""
                   Margin="0,6,0,0"
                   Foreground="DarkSlateBlue"/>
    </Grid>
</Window>
