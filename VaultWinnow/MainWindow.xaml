<Window x:Class="VaultWinnow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VaultWinnow"
        Title="VaultWinnow"
        Height="600" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <!-- Ctrl+O: Open JSON -->
        <KeyBinding Modifiers="Control"
                    Key="O"
                    Command="{Binding OpenCommand}" />

        <!-- Ctrl+W Close file -->
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding CloseCommand}" />

        <!-- Ctrl+E: Export Selected -->
        <KeyBinding Modifiers="Control"
                    Key="E"
                    Command="{Binding ExportCommand}" />

        <!-- Ctrl+C: Copy JSON -->
        <KeyBinding Modifiers="Control"
                    Key="C"
                    Command="{Binding CopyCommand}" />

        <!-- Ctrl+A: Select All (visible) -->
        <KeyBinding Modifiers="Control"
                    Key="A"
                    Command="{Binding SelectAllCommand}" />

        <!-- Ctrl+L: Clear Selection (visible) -->
        <KeyBinding Modifiers="Control"
                    Key="L"
                    Command="{Binding ClearSelectionCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle"
               TargetType="Button">
            <Setter Property="Padding"
                    Value="4,2" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="MinWidth"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

        <!-- Icon + text style that builds on ToolbarButtonStyle -->
        <Style x:Key="ToolbarIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Center">
                            <Image Width="28"
                                   Height="28"
                                   Margin="0,0,0,2"
                                   Source="{Binding RelativeSource={RelativeSource AncestorType=Button},
                                                    Path=Tag}" />
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="11"
                                       Text="{Binding RelativeSource={RelativeSource AncestorType=Button},
                                                      Path=Content}" />
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <local:SelectedRowDiffConverter x:Key="SelectedRowDiffConverter" />
        <local:SelectedRowDiffMultiConverter x:Key="SelectedRowDiffMultiConverter" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0 Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- 1 Search -->
            <RowDefinition Height="Auto"/>
            <!-- 2 Options -->
            <RowDefinition x:Name="GridRowMain" Height="*"/>
            <!-- 3 DataGrid -->
            <RowDefinition x:Name="GridRowSplitter" Height="0"/>
            <!-- 4 Splitter -->
            <RowDefinition x:Name="GridRowDetails" Height="0"/>
            <!-- 5 Details -->
            <RowDefinition Height="Auto"/>
            <!-- 6 Footer -->
        </Grid.RowDefinitions>

        <!-- Toolbar Row -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">

            <!-- File actions -->
            <Button Name="BtnOpen"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/open.png"
                    Content="Open"
                    ToolTip="Open JSON File (CTRL+O)"
                    MinWidth="48"
                    Height="52"
                    Click="BtnOpenClick" />

            <Button x:Name="BtnClose"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/close.png"
                    Content="Close"
                    ToolTip="Close current file"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnCloseClick" />

            <Button Name="BtnExport"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-save.png"
                    Content="Export"
                    ToolTip="Export JSON File (CTRL+E)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnExportClick" />

            <Button Name="BtnCopyToClipboard"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-copy.png"
                    Content="Copy"
                    ToolTip="Copy JSON to Clipboard (CTRL+C)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnCopyToClipboardClick" />

            <Button Name="BtnAppendToJson"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/json-append.png"
                    Content="Append"
                    ToolTip="Append JSON to Existing File"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnAppendToJsonClick" />

            <Separator Margin="8,0,8,0" />

            <!-- Selection actions -->
            <Button Name="BtnSelectAll"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/check-select-all.png"
                    Content="Select"
                    ToolTip="Select All Listed Items (CTRL+A)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnSelectAllClick" />

            <Button Name="BtnClearSelection"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/check-clear.png"
                    Content="Clear"
                    ToolTip="Clear All Listed Items (CTRL+L)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnClearSelectionClick" />

            <Button Name="BtnInvertSelection"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/invert.png"
                    Content="Invert"
                    ToolTip="Invert selection for visible items"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnInvertSelectionClick" />

            <Separator Margin="8,0,8,0" />

            <!-- Duplicate analysis actions -->
            <Button Name="BtnAnalyzeDuplicates"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/analyze.png"
                    Content="Analyze"
                    ToolTip="Analyze logins for duplicates"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnAnalyzeDuplicatesClick" />

            <Button Name="BtnDuplicateHelp"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/message-question.png"
                    Content="Dup Help"
                    ToolTip="Explain Strict / Almost duplicate analysis"
                    MinWidth="48"
                    Height="52"
                    Click="BtnDuplicateHelpClick" />

            <Button Name="BtnSelectStrictDuplicates"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="Assets/Icons/select-strict.png"
                    Content="Select Strict"
                    ToolTip="Select strict duplicates in the visible items (keep one per group)"
                    MinWidth="48"
                    Height="52"
                    IsEnabled="False"
                    Click="BtnSelectStrictDuplicatesClick" />

            <Separator Margin="8,0,8,0" />

            <!-- App -->
            <Button Name="BtnAbout"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Tag="/Assets/Icons/info.png"
                    Content="About"
                    ToolTip="About VaultWinnow"
                    MinWidth="48"
                    Height="52"
                    Click="BtnAboutClick" />
        </StackPanel>

        <!-- Status Row -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,6">
            <TextBlock Text="Search:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBox Name="TxtSearch"
                     Width="220"
                     TextChanged="TxtSearch_TextChanged" />

            <TextBlock Name="TxtStatus"
                       Text="No file loaded."
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="Gray" />
        </StackPanel>

        <!-- Filters and column options (collapsible) -->
        <Expander Grid.Row="2"
                  Header="Options"
                  IsExpanded="False"
                  Margin="0,0,0,4">
            <StackPanel Orientation="Vertical">

                <!-- Types row -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <TextBlock Text="Types:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />

                    <CheckBox x:Name="ChkLogin"
                              Content="Logins"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="TypeFilterCheckboxChanged"
                              Unchecked="TypeFilterCheckboxChanged" />

                    <CheckBox x:Name="ChkSecureNote"
                              Content="Secure Notes"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="TypeFilterCheckboxChanged"
                              Unchecked="TypeFilterCheckboxChanged" />

                    <CheckBox x:Name="ChkCard"
                              Content="Cards"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="TypeFilterCheckboxChanged"
                              Unchecked="TypeFilterCheckboxChanged" />

                    <CheckBox x:Name="ChkIdentity"
                              Content="Identities"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="TypeFilterCheckboxChanged"
                              Unchecked="TypeFilterCheckboxChanged" />

                    <CheckBox x:Name="ChkShowOnlyDuplicates"
                              Content="Show only duplicates"
                              IsChecked="false"
                              IsEnabled="false"
                              Margin="12,0,0,0"
                              Checked="DuplicatesFilterChanged"
                              Unchecked="DuplicatesFilterChanged" />
                </StackPanel>

                <!-- Columns row -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Columns:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />

                    <CheckBox x:Name="ChkColDup"
                              Content="Dup"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />

                    <CheckBox x:Name="ChkColDupCount"
                              Content="#Dup"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />

                    <CheckBox x:Name="ChkColDupGroup"
                              Content="Grp"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />

                    <CheckBox x:Name="ChkColMfa"
                              Content="MFA"
                              IsChecked="True"
                              Margin="12,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />

                    <CheckBox x:Name="ChkColPasskey"
                              Content="Passkey"
                              IsChecked="True"
                              Margin="0,0,6,0"
                              Checked="ColumnVisibilityChanged"
                              Unchecked="ColumnVisibilityChanged" />
                </StackPanel>

            </StackPanel>
        </Expander>
        <!-- DataGrid with watermark -->
        <Grid Grid.Row="3">
            <DataGrid Name="ItemGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      SelectionChanged="ItemGrid_SelectionChanged">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White" />
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="FontWeight" Value="Normal" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Style.Triggers>
                            <!-- Related rows in the same duplicate group -->
                            <DataTrigger Binding="{Binding IsInSelectedDuplicateGroup}" Value="True">
                                <Setter Property="Background" Value="#FFDCEEFF" />
                            </DataTrigger>

                            <!-- Active selected row -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF8FC2F7" />
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <!-- Checkbox -->
                    <DataGridTemplateColumn Header="✔"
                                            Width="40"
                                            MinWidth="40"
                                            CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected,
                                              Mode=TwoWay,
                                              UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Main text columns flex -->
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        MinWidth="150"
                                        Width="2*" 
                                        IsReadOnly="True" />

                        <DataGridTextColumn Header="Username"
                                            Binding="{Binding Username}"
                                            MinWidth="120"
                                            Width="*"
                                            IsReadOnly="True" />

                        <DataGridTextColumn Header="Primary URI"
                                            Binding="{Binding PrimaryUri}"
                                            MinWidth="140"
                                            Width="2*"
                                            IsReadOnly="True" />

                        <!-- Small columns, fixed + MinWidth so headers don’t squash -->
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding TypeLabel}"
                                            Width="70"
                                            MinWidth="70"
                                            IsReadOnly="True" />

                    <DataGridTextColumn Header="Dup"
                                        Binding="{Binding DuplicateStatusDisplay}"
                                        Width="80"
                                        IsReadOnly="True">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                        Value="Duplicate status for logins: Strict (safe auto‑select), Almost (needs review), or blank (no duplicates)." />
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="#Dup"
                                        Binding="{Binding DuplicateGroupSize}"
                                        Width="60"
                                        IsReadOnly="True">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                        Value="How many items are in this duplicate group. 1 means no duplicates; 2+ means multiple related logins." />
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Grp"
                                        Binding="{Binding DuplicateGroupId}"
                                        Width="80"
                                        IsReadOnly="True">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                        Value="Stable duplicate group id so related Strict/Almost logins stay together when sorted." />
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Diff"
                        Width="90"
                        IsReadOnly="True">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <ToolTip MaxWidth="260">
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="Difference code order:" FontWeight="Bold" />
                                                <LineBreak />
                                                <Run Text="N = Name differs" />
                                                <LineBreak />
                                                <Run Text="U = Username differs" />
                                                <LineBreak />
                                                <Run Text="P = Password differs" />
                                                <LineBreak />
                                                <Run Text="O = Notes differ" />
                                                <LineBreak />
                                                <Run Text="T = TOTP differs" />
                                                <LineBreak />
                                                <Run Text="K = Passkey differs" />
                                                <LineBreak />
                                                <Run Text="- = same as selected row" />
                                            </TextBlock>
                                        </ToolTip>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                       TextAlignment="Left"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       Background="Transparent"
                                       Padding="3,1,3,1">
<TextBlock FontFamily="Consolas"
           TextAlignment="Left"
           VerticalAlignment="Center"
           Padding="3,1,3,1">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInSelectedDuplicateGroup}" Value="True">
                                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                                        <Setter Property="Background" Value="#333399" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>

                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource SelectedRowDiffMultiConverter}">
                                                <Binding />
                                                <Binding ElementName="ItemGrid" Path="SelectedItem" />
                                            </MultiBinding>
                                        </TextBlock.Text>
</TextBlock>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Folder"
                                            Binding="{Binding FolderName}"
                                            Width="80"
                                            MinWidth="50"
                                            IsReadOnly="True" />

                    <DataGridCheckBoxColumn Header="MFA"
                                            Binding="{Binding HasTotp, Mode=OneWay}"
                                            Width="50"
                                            IsReadOnly="True">
                                            <DataGridCheckBoxColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                            Value="Checked if this login has a TOTP MFA code configured." />
                                                </Style>
                                            </DataGridCheckBoxColumn.HeaderStyle>
                    </DataGridCheckBoxColumn>

                    <DataGridCheckBoxColumn Header="Passkey"
                                            Binding="{Binding HasPasskey, Mode=OneWay}"
                                            Width="70"
                                            IsReadOnly="True">
                                            <DataGridCheckBoxColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="ToolTip"
                                            Value="Checked if this login has any passkey (FIDO2) credentials." />
                                                </Style>
                                            </DataGridCheckBoxColumn.HeaderStyle>
                    </DataGridCheckBoxColumn>

                </DataGrid.Columns>
            </DataGrid>

            <!-- Faded logo watermark when there are no items -->
            <Image Source="pack://application:,,,/Assets/VaultWinnowLogo.png"
                   Width="200"
                   Height="200"
                   Opacity="0.33"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Items.Count}"
                             Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

        </Grid>

        <GridSplitter Grid.Row="4"
              Height="5"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center"
              Background="#D0D0D0"
              ResizeDirection="Rows"
              ResizeBehavior="PreviousAndNext"
              ShowsPreview="True"/>

        <!-- Selected item details pane -->
        <Border Grid.Row="5"
        Margin="0,6,0,0"
        Padding="8"
        BorderBrush="#FFB7B7C9"
        BorderThickness="1"
        Background="#FFF7F7FB">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header with title + X -->
                        <RowDefinition Height="*"/>
                        <!-- Existing details content -->
                    </Grid.RowDefinitions>

                    <!-- Header row: title + X -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Selected Item Details"
                           FontWeight="SemiBold"
                           Foreground="DarkSlateBlue"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                        <Button x:Name="BtnCloseDetails"
                        Content="✕"
                        Width="22"
                        Height="22"
                        Padding="0"
                        Margin="6,0,0,0"
                        ToolTip="Close details pane"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="BtnCloseDetailsClick"
                        DockPanel.Dock="Right"/>
                    </DockPanel>

                    <!-- Existing details content moved into Grid.Row=1 -->
                    <Grid Grid.Row="1">
                        <!-- Now 4 rows: title, selected item grid, compared-items list, bottom note -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: title (keep, or remove if redundant with header) -->
                        <TextBlock Grid.Row="0"
                           Text="Selected item and comparisons"
                           FontWeight="SemiBold"
                           Foreground="DarkSlateBlue"
                           Margin="0,0,0,6"/>

                        <!-- Row 1: selected item metadata -->
                        <Grid Grid.Row="1"
                      DataContext="{Binding SelectedItem, ElementName=ItemGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" Margin="0,0,6,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="0,0,12,4"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Username:" FontWeight="SemiBold" Margin="0,0,6,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Username}" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Primary URI:" FontWeight="SemiBold" Margin="0,0,6,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                               Margin="8,0,0,0"
                               Text="{Binding PrimaryUri}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding PrimaryUri}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Dup status:" FontWeight="SemiBold" Margin="0,0,6,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DuplicateStatusDisplay}" Margin="0,0,12,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Group:" FontWeight="SemiBold" Margin="0,0,6,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding DuplicateGroupId}" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="#Dup:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DuplicateGroupSize}" Margin="0,0,12,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Diff:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                            <TextBlock Grid.Row="3"
                               Grid.Column="3"
                               Text="{Binding DiffDisplay}"
                               FontFamily="Consolas"
                               FontWeight="SemiBold"/>
                        </Grid>

                        <!-- Row 2: compared-items list -->
                        <StackPanel Grid.Row="2" Margin="0,8,0,0">
                            <TextBlock Text="Compared items in this group:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>

                            <ItemsControl ItemsSource="{Binding SelectedGroupItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Width="80"
                                                   FontFamily="Consolas"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DiffDisplay}" />

                                                <TextBlock Width="220"
                                                   Margin="8,0,0,0"
                                                   Text="{Binding Name}" />

                                                <TextBlock Width="260"
                                                   Margin="8,0,0,0"
                                                   Foreground="DimGray"
                                                   Text="{Binding Username}" />

                                                <TextBlock Margin="8,0,0,0"
                                                   Foreground="DimGray"
                                                   FontStyle="Italic"
                                                   Text="{Binding DiffDisplayDescription}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Row 3: bottom note -->
                        <TextBlock Grid.Row="3"
                           Margin="0,8,0,0"
                           Foreground="DimGray"
                           Text="This pane will expand to show more Almost-duplicate comparison detail."
                           FontStyle="Italic"/>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="6"
                   Name="TxtCount"
                   Text=""
                   Margin="0,6,0,0"
                   Foreground="DarkSlateBlue"/>
    </Grid>
</Window>
